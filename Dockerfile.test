# syntax=docker/dockerfile:1.7
#
# Test image: runs the full test matrix against a real LibreOffice install —
# host `go test` can't exercise the cgo LOK path. Separate from the runtime
# Dockerfile so the legacy Docker builder (DOCKER_BUILDKIT=0) of the runtime
# image doesn't drag the test stages along as a side effect.
#
# Ubuntu base because the integration test loads PDFs as Draw documents via
# pdfimport, which Debian bookworm no longer ships as a standalone package.

FROM ubuntu:24.04 AS test

ENV CGO_ENABLED=1 \
    GOFLAGS="-trimpath" \
    GOPROXY=https://proxy.golang.org,direct \
    LOK_PATH=/usr/lib/libreoffice/program \
    GODEBUG=asyncpreemptoff=1
# GODEBUG=asyncpreemptoff=1: required for LO+cgo (see Dockerfile runtime stage).
# The integration tests load LO too, so without this they would crash on the
# first preempt that lands while LO C code is on stack.

# Install the LO app-targets needed by internal/worker/integration_test.go's
# fixtures plus the toolchain to build cgo. media-types provides /etc/mime.types
# for extensionFromContentType's fallback lookups.
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        golang-go \
        build-essential \
        ca-certificates \
        pkg-config \
        libx11-dev \
        libreoffice-core \
        libreoffice-writer \
        libreoffice-calc \
        libreoffice-impress \
        media-types \
        fonts-liberation \
        fonts-dejavu-core \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

# `-tags=integration` covers the unit tests too (Go build tags are
# additive, not exclusive). cover-gate runs separately because it
# uses `-tags=nolok` to swap the cgo adapter for a stub — the
# resulting profile is incompatible with the integration build.
RUN go vet ./... \
 && gofmt -s -l . | (! grep .) \
 && go test -race ./... \
 && go test -tags=integration ./... \
 && make cover-gate
# Race detector runs on the pure-Go suite; the integration build excludes
# -race because LO/cgo corrupts glibc heap state across conversions and
# the race finalizer trips at process exit (tests pass but exit crashes).
